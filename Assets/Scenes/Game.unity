--- !u!114 &847053687
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 847053684}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9aedb0449a015ed449eb4f28bc75ccb4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager
  tutorialDialogues:
  - text: "\uBCF8\uC0AC\uC758 \uBC30\uC1A1 \uC5C5\uBB34 \uC2E0\uC785 \uD6C8\uB828
      \uC2DC\uC2A4\uD15C\uC5D0 \uC624\uC2E0 \uAC83\uC744 \uD658\uC601\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uADC0\uD558\uB294 \uBCF8\uC0AC \uBC29\uCE68\uC5D0 \uB530\uB77C \uBC30\uC1A1
      \uC5C5\uBB34\uB97C \uC9C4\uD589\uD558\uAC8C\uB429\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC7A5\uBE44 \uB178\uD6C4\uC640 \uADC0\uD558\uC758 \uC2E4\uB825\uC5D0
      \uB530\uB978 \uC5C5\uBB34 \uC911 \uBC1C\uC0DD\uD558\uB294 \uC0AC\uACE0\uC5D0
      \uB300\uD574\\n\uBCF8\uC0AC\uB294 \uCC45\uC784\uC9C0\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC791\uC5C5\uC790\uC758 \uCD5C\uC18C\uD55C\uC758 \uC548\uC804\uC744 \uC704\uD55C
      \uAD50\uC721\uC744 \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uADC0\uD558\uB294 6\uAC1C\uC758 \uC2DC\uC2A4\uD15C\uC73C\uB85C \uC774\uB8E8\uC5B4\uC9C4
      \uBCF8\uC0AC\uC758 \uC7A5\uBE44\uB97C \uD1B5\uD574\\n\uBC30\uC1A1 \uC5C5\uBB34\uB97C
      \uC9C4\uD589\uD558\uAC8C \uB429\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC88C\uCE21 \uC0C1\uB2E8\uC758 \uBAA8\uB2C8\uD130\uB294 \uD604\uC7AC
      \uC0C1\uD0DC\uB97C \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uCD1D 3\uAC1C\uC758 \uC0C1\uD0DC
      \uAC8C\uC774\uC9C0\uAC00 \uC874\uC7AC\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uD770\uC0C9 \uAC8C\uC774\uC9C0\uB294 \uBC30\uC1A1 \uC9C4\uD589\uB3C4\uB97C
      \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uC6CC\uD504\uB97C \uD1B5\uD574 \uC9C4\uD589\uB3C4\uB97C
      \uCC44\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uB179\uC0C9 \uAC8C\uC774\uC9C0\uB294 \uC7A5\uBE44\uC758 \uB0B4\uAD6C\uB3C4\uB97C
      \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uC7A5\uBE44 \uD30C\uAD34\uB85C \uC778\uD55C
      \uC0AC\uACE0\uC5D0 \uB300\uD558\uC5EC \uBCF8\uC0AC\uB294 \uCC45\uC784\uC9C0\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uD669\uC0C9 \uAC8C\uC774\uC9C0\uB294 \uC7A5\uBE44\uC758 \uC804\uB825
      \uC0C1\uD0DC\uB97C \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n[Space]\uB97C \uC774\uC6A9\uD574
      \uC804\uB825\uC744 \uC0DD\uC0B0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\uC804\uB825\uC774
      0\uC774 \uB420 \uC2DC \uBAA8\uB4E0 \uBAA8\uB2C8\uD130 \uD654\uBA74\uC774 \uAEBC\uC9D1\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC911\uC559 \uC0C1\uB2E8\uC758 \uBAA8\uB2C8\uD130\uB294 \uC7A5\uBE44\uC758
      \uADE0\uD615 \uC870\uC808 \uC2DC\uC2A4\uD15C\uC744 \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n
      [\uBC29\uD5A5\uD0A4]\uB97C \uC774\uC6A9\uD574 \uC218\uB3D9\uC73C\uB85C \uC870\uC808\uC774
      \uAC00\uB2A5\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC77C\uC815 \uC218\uC900 \uC774\uC0C1\uC73C\uB85C \uADE0\uD615\uC774
      \uC0C1\uC2E4\uB420 \uC2DC \uBE44\uC0C1 \uC2DC\uC2A4\uD15C\uC774 \uC791\uB3D9\uD558\uC9C0\uB9CC\\n\uC7A5\uBE44
      \uB0B4\uAD6C\uB3C4\uC5D0 \uC601\uD5A5\uC744 \uC8FC\uB294 \uCDA9\uACA9\uC774
      \uBC1C\uC0DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC6B0\uCE21 \uC0C1\uB2E8\uC758 \uBAA8\uB2C8\uD130\uB294 \uCDA9\uB3CC
      \uAC10\uC9C0 \uBC0F \uBC29\uC5B4 \uC2DC\uC2A4\uD15C\uC744 \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uD2B9\uC815
      \uBC29\uD5A5\uC5D0\uC11C \uCDA9\uB3CC \uC608\uC0C1 \uC2DC\uAC04\uC744 \uACC4\uC0B0\uD574
      \uBCF4\uC5EC\uC90D\uB2C8\uB2E4.\\n[\uC22B\uC790\uD0A4]\uB97C \uC774\uC6A9\uD574
      \uBC30\uB9AC\uC5B4 \uC804\uAC1C\uAC00 \uAC00\uB2A5\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "[5]\uB97C \uC81C\uC678\uD55C [\uC22B\uC790\uD0A4]\uB294 \uD574\uB2F9 \uBC29\uD5A5\uC758
      \uBC30\uB9AC\uC5B4\uB97C \uC804\uAC1C\uD569\uB2C8\uB2E4. \\n[5]\uD0A4\uC758
      \uACBD\uC6B0 \uBAA8\uB4E0 \uBC30\uB9AC\uC5B4\uB97C \uB044\uAC70\uB098 \uCF2D\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uBC30\uB9AC\uC5B4\uB85C \uCDA9\uB3CC\uC744 \uB9C9\uC9C0 \uBABB\uD560\uC2DC\uC5D0
      \uC7A5\uBE44 \uB0B4\uAD6C\uB3C4\uC5D0 \uC601\uD5A5\uC744 \uC904 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\uBC30\uB9AC\uC5B4\uB294
      \uC804\uB825\uC744 \uBE60\uB974\uAC8C \uC18C\uBAA8\uC2DC\uD0AC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC88C\uCE21 \uD558\uB2E8\uC758 \uBAA8\uB2C8\uD130\uB294 \uC6CC\uD504
      \uC2DC\uC2A4\uD15C\uC744 \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uC6CC\uD504 \uD3EC\uC778\uD2B8\uB97C
      \uC790\uB3D9\uC73C\uB85C \uAC10\uC9C0\uD574 \uBAA8\uB2C8\uD130\uC5D0 \uCD9C\uB825\uD569\uB2C8\uB2E4.\\n[WASD]\uD0A4\uB85C
      \uC6CC\uD504 \uD3EC\uC778\uD2B8\uB85C \uC774\uB3D9 \uD6C4\uC5D0 [Q]\uD0A4\uB97C
      \uAFB9 \uB20C\uB7EC \uC6CC\uD504\uD558\uC2ED\uC2DC\uC624."
    isNeedChoice: 0
    choices: []
  - text: "\uC88C\uCE21 \uC911\uC559\uC758 \uBAA8\uB2C8\uD130\uB294 \uC7A5\uBE44\uB97C
      \uAD00\uB9AC\uD558\uB294 AI\uC6A9 \uBAA8\uB2C8\uD130\uC785\uB2C8\uB2E4.\\n\uC7A5\uBE44\uC758
      \uAE30\uD0C0 \uC2DC\uC2A4\uD15C\uC744 \uAD00\uB9AC\uD558\uBA70 \uADC0\uD558\uC758
      \uC784\uBB34\uB97C \uBCF4\uC870\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uAC00\uB054\uC529 \uC5D0\uB7EC\uAC00 \uBC1C\uC0DD\uD558\uB098 \uD654\uBA74\uC758
      [\uBCF4\uC548\uCF54\uB4DC]\uB97C \uC785\uB825\uD574 \uD574\uACB0\uC774 \uAC00\uB2A5\uD569\uB2C8\uB2E4.\\n\uC77C\uC815
      \uD69F\uC218 \uC774\uC0C1 \uBCF4\uC548 \uCF54\uB4DC\uB97C \uD2C0\uB9B4 \uC2DC\uC5D0\uB294\\n\uC2DC\uC2A4\uD15C
      \uC7AC\uBD80\uD305\uC744 \uC2E4\uD589\uD558\uB2C8 \uC8FC\uC758\uD558\uC2ED\uC2DC\uC624."
    isNeedChoice: 0
    choices: []
  - text: "\uC5D0\uB7EC\uAC00 \uBC1C\uC0DD\uD55C \uACBD\uC6B0 \uB2E4\uB978 \uC2DC\uC2A4\uD15C\uC774
      \uC785\uB825\uC774 \uBD88\uAC00\uB2A5\uD574\uC9D1\uB2C8\uB2E4.\\n\uC5D0\uB7EC
      \uCF54\uB4DC\uB97C \uCD5C\uC6B0\uC120\uC73C\uB85C \uD574\uACB0\uD558\uC2ED\uC2DC\uC624.\\n\uC5D0\uB7EC\uAC00
      \uC0DD\uAE34 \uC0C1\uD669\uC5D0 \uC804\uB825\uC774 0\uC774 \uB418\uBA74 \uC790\uAC00
      \uBCF5\uAD6C\uB97C \uC9C4\uD589\uD569\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC6B0\uCE21 \uD558\uB2E8\uC758 \uBAA8\uB2C8\uD130\uB294 \uBC30\uC1A1
      \uD654\uBB3C \uC0C1\uD0DC\uB97C \uB098\uD0C0\uB0C5\uB2C8\uB2E4.\\n\uD5D0\uAC70\uC6CC\uC9C4
      \uD654\uBB3C \uCE78\uC744 [UIOJKL]\uD0A4\uB97C \uAFB9 \uB20C\uB7EC \uAD00\uB9AC\uD558\uC2ED\uC2DC\uC624.\\n\uD654\uBB3C\uC774
      \uD480\uB9B4 \uC2DC\uC5D0\uB294 \uC7A5\uBE44\uC758 \uADE0\uD615\uC774 \uAC15\uD558\uAC8C
      \uC190\uC2E4\uB420 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 0
    choices: []
  - text: "\uC774\uC0C1\uC73C\uB85C \uBCF8\uC0AC\uC758 \uBC30\uC1A1 \uC5C5\uBB34
      \uC2E0\uC785 \uD6C8\uB828 \uC2DC\uC2A4\uD15C\uC5D0 \uB300\uD55C \uC548\uB0B4\uAC00
      \uB05D\uB0AC\uC2B5\uB2C8\uB2E4."
    isNeedChoice: 1
    choices:
    - targetKey: 13
      onTargetKeyDown:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 847053687}
            m_TargetAssemblyTypeName: GameManager, Assembly-CSharp
